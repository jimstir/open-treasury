{
  "name": "contracts",
  "version": "1.0.0",
  "description": "This directory contains the smart contracts for the Open Treasury project.",
  "main": "hardhat.config.js",
  "scripts": {
    "test": "npx hardhat test",
    "test:vault": "npx hardhat test scripts/test/treasuryVault.test.js",
    "test:buyback": "npx hardhat test scripts/test/buyBack.test.js",
    "test:crowdsale": "npx hardhat test scripts/test/crowdsale.test.js",
    "test:lending": "npx hardhat test scripts/test/lending.test.js",
    "test:all": "npm run test:vault && npm run test:buyback && npm run test:crowdsale && npm run test:lending",
    "export-artifacts": "hardhat run scripts/deploy/export-artifacts.js",
    "deploy": "hardhat run scripts/deploy/deploy.js",
    "deploy:sepolia": "hardhat run scripts/deploy/deploy.js --network sepolia",
    "deploy:goerli": "hardhat run scripts/deploy/deploy.js --network goerli",
    "deploy:mumbai": "hardhat run scripts/deploy/deploy.js --network mumbai",
    "deploy:token": "hardhat run scripts/deploy/deploy.js --network sepolia TreasuryToken",
    "deploy:vault": "hardhat run scripts/deploy/deploy.js --network sepolia TreasuryVault",
    "deploy:buyback": "hardhat run scripts/deploy/deploy.js --network sepolia BuyBack",
    "deploy:crowdsale": "hardhat run scripts/deploy/deploy.js --network sepolia Crowdsale",
    "deploy:lending": "hardhat run scripts/deploy/deploy.js --network sepolia Lending",
    "deploy:joinpool": "hardhat run scripts/deploy/deploy.js --network sepolia JoinPool"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bgd-labs/aave-address-book": "^4.23.0",
    "@openzeppelin/contracts": "^5.3.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "chai": "^4.3.7",
    "dotenv": "^17.3.1",
    "ethereum-waffle": "^4.0.10",
    "ethers": "^6.16.0",
    "hardhat": "^2.19.0",
    "hardhat-abi-exporter": "^2.10.1"
  }
}
