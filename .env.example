# Environment variables for Open Treasury

# Application
NODE_ENV=development
PORT=4000

# Database Configuration
# For SQLite (default in development)
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./lib/api-server/prisma/dev.db"

# For PostgreSQL (used in Docker)
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/treasury?schema=public"

# API Configuration
API_BASE_URL=http://localhost:4000

# Deployment Settings (for deploy-treasury.js)
# Set to true to save deployments to the database
DEPLOY_SAVE_TO_DB=false
# URL of the API server to save deployments to
DEPLOY_API_URL=http://localhost:4000/api/deployed-treasuries

# Ethereum Network Configuration
# For local development with Hardhat
ETHEREUM_RPC_URL=http://localhost:8545
# For mainnet or testnet
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Wallet Configuration (for deployment)
# PRIVATE_KEY=your_private_key_here
# MNEMONIC="your mnemonic phrase here"

# API Keys (if using external services)
# INFURA_API_KEY=your_infura_key_here
# ALCHEMY_API_KEY=your_alchemy_key_here
# ETHERSCAN_API_KEY=your_etherscan_key_here
